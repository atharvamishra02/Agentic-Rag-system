# Dockerfile.python - Multi-stage build to reduce final image size

# Stage 1: Builder - includes build tools
FROM python:3.11-slim AS builder

WORKDIR /app

# Install build dependencies in one layer and clean immediately
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Install CPU-only PyTorch and compatible NumPy (prevents SIMD baseline optimizations crash)
RUN pip install --no-cache-dir torch numpy==1.26.4 --index-url https://download.pytorch.org/whl/cpu

# Copy and install Python requirements
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Stage 2: Runtime - minimal image without build tools
FROM python:3.11-slim

WORKDIR /app

# Copy only the installed packages from builder
COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy application code
COPY . .

# Ensure temp directory exists
RUN mkdir -p temp_uploads

# Set thread count environment variables to optimize CPU and RAM usage
ENV OMP_NUM_THREADS=1
ENV MKL_NUM_THREADS=1
ENV OPENBLAS_NUM_THREADS=1
ENV VECLIB_MAXIMUM_THREADS=1
ENV NUMEXPR_NUM_THREADS=1

# Expose port
EXPOSE 8000

# Start application
CMD ["python", "rag_api.py"]
